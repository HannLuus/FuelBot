# Supabase – copy this file to .env and fill in values from the dashboard.
# Get these from: https://supabase.com/dashboard/project/feenwusofmhnpuahekvu/settings/api

# Vite exposes env vars prefixed with VITE_ to the browser bundle.

# Project reference (from project URL or Settings > General)
SUPABASE_PROJECT_REF=feenwusofmhnpuahekvu

# API URL (Settings > API > Project URL)
VITE_SUPABASE_URL=https://feenwusofmhnpuahekvu.supabase.co

# Anon/public key – safe for client-side (Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=

# Service role key – server-only (Edge Functions only, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: salt for device hash privacy (any random string)
VITE_DEVICE_HASH_SALT=change-me-to-random-string

# Operator payment instructions and QR for annual station subscriptions
VITE_PAYMENT_INSTRUCTIONS=Pay annual subscription via KBZ Pay, WavePay, or bank transfer.
VITE_PAYMENT_QR_URL=

# Admin notifications
VITE_ADMIN_NOTIFICATION_EMAIL=best.iptvmm@gmail.com
ADMIN_NOTIFICATION_EMAIL=best.iptvmm@gmail.com

# Tier pricing (MMK per year)
VITE_TIER_PRICE_SMALL_MMK=500000
VITE_TIER_PRICE_MEDIUM_MMK=1200000
VITE_TIER_PRICE_LARGE_MMK=2500000
TIER_PRICE_SMALL_MMK=500000
TIER_PRICE_MEDIUM_MMK=1200000
TIER_PRICE_LARGE_MMK=2500000

# Optional app URL for admin notification email links
APP_URL=https://fuelbot.vercel.app/admin

# Gemini API – for scripts/source-stations-gemini.mjs (sourcing Yangon/Mandalay fuel stations)
# Get a key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
