# FuelBot — self-hosted Supabase on VPS (not Supabase Cloud)
# Copy to .env.local for local dev. Get keys from Studio:
# https://studio.fuelbot.lucas-dev-server.tech

# Vite exposes env vars prefixed with VITE_ to the browser bundle.

# API URL (Kong behind Caddy)
VITE_SUPABASE_URL=https://fuelbot.lucas-dev-server.tech

# Anon/public key — safe for client-side (Studio → Project Settings → API)
VITE_SUPABASE_ANON_KEY=

# Service role — local scripts/imports only; never in Vercel or the browser
SUPABASE_SERVICE_ROLE_KEY=

# Optional: salt for device hash privacy (any random string)
VITE_DEVICE_HASH_SALT=change-me-to-random-string

# Payment instructions, QR URL, optional KPay phone: set in production via Admin → Payment settings (KPay only)
# (table payment_config). No VITE_ vars required for that flow.

# Admin notifications (server-side only — never use a VITE_ prefix for this)
ADMIN_NOTIFICATION_EMAIL=support@fuelbotmm.com

# Invoice emails (Supabase Edge Function secrets — optional overrides)
# INVOICE_COMMERCIAL_TAX_PERCENT=5
# INVOICE_SUPPORT_EMAIL=support@fuelbotmm.com
# INVOICE_COMPANY_NAME=FuelBot

# Station subscription: flat 10,000 MMK/month = 120,000 MMK/year
VITE_STATION_SUBSCRIPTION_ANNUAL_MMK=120000
STATION_SUBSCRIPTION_ANNUAL_MMK=120000

# Optional app URL for admin notification email links (used in emails)
APP_URL=https://fuelbotmm.com

# Resend – sending from your domain (admin@fuelbotmm.com). Set RESEND_API_KEY in VPS Edge Function secrets.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=FuelBot <admin@fuelbotmm.com>

# Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY must be set as VPS Edge Function secrets.
# VITE_VAPID_PUBLIC_KEY must also be set in Vercel so the browser can subscribe.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@fuelbotmm.com

# Cron secret for snapshot-station-statuses — VPS Edge Function secret + cron header
CRON_SECRET=

# Server-side IP rate-limit secret for submit-report (Edge Function secret only, never VITE_)
IP_HASH_SECRET=

# Webhook secret for send-fuel-alerts
SEND_FUEL_ALERTS_WEBHOOK_SECRET=

# Gemini API – for scripts/source-stations-gemini.mjs (sourcing stations)
# GEMINI_API_KEY=
