# Supabase – copy this file to .env and fill in values from the dashboard.
# Get these from: https://supabase.com/dashboard/project/feenwusofmhnpuahekvu/settings/api

# Vite exposes env vars prefixed with VITE_ to the browser bundle.

# Project reference (from project URL or Settings > General)
SUPABASE_PROJECT_REF=feenwusofmhnpuahekvu

# API URL (Settings > API > Project URL)
VITE_SUPABASE_URL=https://feenwusofmhnpuahekvu.supabase.co

# Anon/public key – safe for client-side (Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=

# Service role key – server-only (Edge Functions only, never exposed to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: salt for device hash privacy (any random string)
VITE_DEVICE_HASH_SALT=change-me-to-random-string

# Operator payment: instructions, QR image URL, and phone numbers (WavePay / KPay)
VITE_PAYMENT_INSTRUCTIONS=Pay 10,000 MMK/month via WavePay or KBZ Pay. Put your station name in the reference.
VITE_PAYMENT_QR_URL=
VITE_PAYMENT_PHONE_WAVEPAY=
VITE_PAYMENT_PHONE_KPAY=

# Admin notifications (server-side only — never use a VITE_ prefix for this)
ADMIN_NOTIFICATION_EMAIL=best.iptvmm@gmail.com

# Station subscription: flat 10,000 MMK/month = 120,000 MMK/year
VITE_STATION_SUBSCRIPTION_ANNUAL_MMK=120000
STATION_SUBSCRIPTION_ANNUAL_MMK=120000

# Optional app URL for admin notification email links
APP_URL=https://fuelbot.vercel.app/admin

# Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY must be set as Supabase Edge Function secrets.
# VITE_VAPID_PUBLIC_KEY must also be set in Vercel so the browser can subscribe.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@fuelbot.app

# Webhook secret for send-fuel-alerts — set in Supabase Webhooks > Authorization header
SEND_FUEL_ALERTS_WEBHOOK_SECRET=

# Gemini API – for scripts/source-stations-gemini.mjs (sourcing stations)
# Get a key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=

# Optional: use Vertex AI instead (e.g. to avoid geo-restriction). Set USE_VERTEX_AI=1 and:
# – VERTEX_API_KEY=your_vertex_key (or reuse GEMINI_API_KEY if using Vertex Express), and optionally
#   VERTEX_LOCATION=us-central1
# – or VERTEX_PROJECT=your-gcp-project + VERTEX_LOCATION=us-central1 (auth via gcloud / GOOGLE_APPLICATION_CREDENTIALS)
# USE_VERTEX_AI=0
# VERTEX_API_KEY=
# VERTEX_LOCATION=us-central1
